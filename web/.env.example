# =============================================================================
# Jira MCP Web UI: environment configuration template.
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
# =============================================================================

# Base URL of the running Python MCP server's streamable HTTP endpoint.
MCP_SERVER_URL=http://localhost:8765/mcp

# Anthropic key powers the /chat page. Leave blank to disable chat.
ANTHROPIC_API_KEY=

# Used to construct "Open in Jira" links from issue keys (no trailing slash).
JIRA_BROWSE_URL=https://ttmcp.atlassian.net
