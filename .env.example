# =============================================================================
# Jira MCP Server: environment configuration template.
# Copy to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Jira connection
# -----------------------------------------------------------------------------

# Your Jira Cloud base URL. Must be HTTPS.
# Example: https://your-domain.atlassian.net
JIRA_BASE_URL=

# Auth mode: api_token | oauth
JIRA_AUTH_MODE=api_token

# API token mode (default)
# Atlassian account email tied to the token.
JIRA_EMAIL=
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# OAuth mode (only needed when JIRA_AUTH_MODE=oauth).
# Create the OAuth 2.0 (3LO) app at https://developer.atlassian.com/console/myapps/
# and copy its client id and secret here. The redirect URI must match the value
# registered with the app exactly; the login script binds a local listener to
# the host and port encoded in this URI (e.g. http://localhost:9000/callback).
# `offline_access` must be in the scope list, otherwise Atlassian will not
# return a refresh token and every restart of the server will need a new login.
JIRA_OAUTH_CLIENT_ID=
JIRA_OAUTH_CLIENT_SECRET=
JIRA_OAUTH_REDIRECT_URI=http://localhost:9000/callback
JIRA_OAUTH_SCOPES=read:jira-work write:jira-work read:jira-user offline_access

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------

# Connection URI.
# Local example: mongodb://localhost:27017
# Atlas example: mongodb+srv://user:pass@cluster.mongodb.net
MONGO_URI=

# Database name.
MONGO_DB=jira_mcp

# -----------------------------------------------------------------------------
# MCP server
# -----------------------------------------------------------------------------

# Transport: stdio (default) | http
MCP_TRANSPORT=stdio

# Only used when MCP_TRANSPORT=http
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8765

# Comma-separated origins allowed by the HTTP transport's CORS policy.
# Default permits a Next.js dev UI on port 3000.
MCP_CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Behaviour flags
# -----------------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Allow destructive operations (issue delete). Default: false.
ALLOW_DELETE_ISSUES=false

# Cache TTL in seconds for hot reads.
CACHE_TTL_SECONDS=300

# Max concurrent Jira requests.
JIRA_MAX_CONCURRENCY=8

# Retry budget for Jira 429 and 5xx responses.
JIRA_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Optional integration
# -----------------------------------------------------------------------------

# Run integration tests against a real Jira instance (used by pytest).
# RUN_INTEGRATION=1
